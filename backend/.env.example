# Local development — copy to backend/.env

OPENSANDBOX_URL=http://localhost:8080
OPENSANDBOX_SESSION_HOST=localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opensandbox
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
VSCODE_IMAGE=sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/opensandbox/vscode:latest
SESSION_TTL_SECONDS=1800
POLL_INTERVAL_SECONDS=10
ACTIVITY_LOG_MAX_EVENTS=50
DEFAULT_SANDBOX_CPU=500m
DEFAULT_SANDBOX_MEMORY=512Mi
DEFAULT_SANDBOX_TIMEOUT=600
SECRET_KEY=dev-secret-key-change-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
# Set to true only when OpenSandbox is configured with network_mode=bridge.
# Leave false (default) when using network_mode=opensandbox-sandbox.
ENABLE_NETWORK_POLICY=false
