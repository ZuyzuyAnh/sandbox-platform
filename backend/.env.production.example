# Backend production environment — copy to backend/.env.production
# Do not commit backend/.env.production (contains secrets).

# OpenSandbox lifecycle API (internal Docker network)
OPENSANDBOX_URL=http://opensandbox:8080

# Public host for VS Code session tabs — MUST match OPENSANDBOX_SESSION_EIP in root .env.production
OPENSANDBOX_SESSION_HOST=203.0.113.10

# Database & Redis (compose service names)
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@postgres:5432/opensandbox
REDIS_URL=redis://redis:6379

# CORS — browser origin(s) that load the dashboard (comma-separated)
# HTTP by IP: http://18.141.116.75   HTTPS with domain: https://sandbox.example.com
CORS_ORIGINS=http://203.0.113.10

# Sandbox image URI (same as VSCODE_IMAGE in root .env.production)
VSCODE_IMAGE=sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/opensandbox/vscode:latest

SESSION_TTL_SECONDS=1800
POLL_INTERVAL_SECONDS=10
ACTIVITY_LOG_MAX_EVENTS=50
DEFAULT_SANDBOX_CPU=500m
DEFAULT_SANDBOX_MEMORY=512Mi
DEFAULT_SANDBOX_TIMEOUT=600

# Optional — only for legacy POST /api/spawn (not used for VS Code sessions)
# ANTHROPIC_AUTH_TOKEN=

# Egress: path inside backend container (mount ./deploy → /deploy in compose)
# SANDBOX_NETWORK_POLICY_PATH=/deploy/network-policy.demo.json
