# Root compose variables — copy to .env.production and fill in values.
# Used by: docker compose -f docker-compose.prod.yaml --env-file .env.production up -d --build

# Public hostname or IP browsers use (Elastic IP, Route53 name, etc.)
OPENSANDBOX_SESSION_EIP=203.0.113.10

# VS Code sandbox image (pre-pull on first deploy)
VSCODE_IMAGE=sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/opensandbox/vscode:latest

# PostgreSQL (compose service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=opensandbox

# Frontend build-time URLs — leave EMPTY to use same origin as the browser (recommended).
# Only set these if the API is on a different host. No trailing slash.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# Host port for nginx (80 or 443 if terminating TLS on the instance)
HTTP_PORT=80
